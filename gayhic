local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local ORB_FOLDER = workspace:WaitForChild("EnergyOrbs")
local TELEPORT_KEY = Enum.KeyCode.T

local player = Players.LocalPlayer
local holding = false
local currentTween = nil

-- Freeze movement but keep collisions
local function freezeCharacter(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = 0
        hum.JumpPower = 0
        hum.JumpHeight = 0
        hum.AutoRotate = false
        hum.PlatformStand = false -- collisions stay ON
    end
end

local function unfreezeCharacter(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = 16
        hum.JumpPower = 50
        hum.JumpHeight = 7.2
        hum.AutoRotate = true
        hum.PlatformStand = false
    end
end

local function getCharacterRoot()
    local char = player.Character or player.CharacterAdded:Wait()
    return char, char:FindFirstChild("HumanoidRootPart")
end

local function getNearestOrb(root)
    local nearest, dist = nil, math.huge
    for _, obj in ipairs(ORB_FOLDER:GetDescendants()) do
        if obj:IsA("BasePart") then
            local d = (obj.Position - root.Position).Magnitude
            if d < dist then
                dist = d
                nearest = obj
            end
        end
    end
    return nearest
end

local function tweenToOrb(root, orb)
    if currentTween then
        currentTween:Cancel()
    end

    local goal = {}
    goal.CFrame = CFrame.new(orb.Position)

    currentTween = TweenService:Create(
        root,
        TweenInfo.new(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
        goal
    )

    currentTween:Play()
end

task.spawn(function()
    while true do
        task.wait(0.05)
        if holding then
            local char, root = getCharacterRoot()
            if root then
                local orb = getNearestOrb(root)
                if orb then
                    freezeCharacter(char)
                    tweenToOrb(root, orb)
                end
            end
        else
            local char = player.Character
            if char then
                unfreezeCharacter(char)
            end
        end
    end
end)

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == TELEPORT_KEY then
        holding = true
    end
end)

UIS.InputEnded:Connect(function(input, gpe)
    if input.KeyCode == TELEPORT_KEY then
        holding = false
    end
end)

-- Mobile button
if UIS.TouchEnabled then
    local gui = Instance.new("ScreenGui")
    gui.ResetOnSpawn = false
    gui.Name = "TPGui"
    gui.Parent = player:WaitForChild("PlayerGui")

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 110, 0, 110)
    button.Position = UDim2.new(1, -130, 1, -150)
    button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    button.BackgroundTransparency = 0.15
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.GothamBold
    button.TextScaled = true
    button.Text = "TP"
    button.Parent = gui
    button.AutoButtonColor = false
    button.BorderSizePixel = 0

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = button

    local uiStroke = Instance.new("UIStroke")
    uiStroke.Thickness = 3
    uiStroke.Color = Color3.fromRGB(0, 170, 255)
    uiStroke.Parent = button

    button.MouseButton1Down:Connect(function()
        holding = true
        button.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
        uiStroke.Thickness = 5
    end)

    button.MouseButton1Up:Connect(function()
        holding = false
        button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        uiStroke.Thickness = 3
    end)
end
